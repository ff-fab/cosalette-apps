{
  "name": "cosalette-apps",
  "build": {
    "dockerfile": "Dockerfile",
    "cacheFrom": "ghcr.io/ff-fab/cosalette-apps-devcontainer"
  },
  "workspaceFolder": "/workspaces/cosalette-apps",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/cosalette-apps,type=bind,consistency=cached",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": false
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "remoteEnv": {
    "PATH": "/home/vscode/.local/bin:/workspaces/cosalette-apps/.venv/bin:${containerEnv:PATH}",
    "UV_LINK_MODE": "copy",
    "GH_PAGER": "cat",
    "CONTEXT7_API_KEY": "${localEnv:CONTEXT7_API_KEY}",
    "OPENCODE_API_KEY": "${localEnv:OPENCODE_API_KEY}"
  },

  "customizations": {
    "vscode": {
      "settings": {
        // Python interpreter in container
        "python.defaultInterpreterPath": "/workspaces/cosalette-apps/.venv/bin/python",
        "python.terminal.activateEnvironment": true,

        // Line length: 88 characters (matches Prettier, Ruff, and Black conventions)
        "editor.rulers": [88],
        "editor.wordWrap": "off",

        // Default formatter for different file types
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true,

        // Python formatting and linting
        "[python]": {
          "editor.rulers": [88],
          "editor.defaultFormatter": "charliermarsh.ruff",
          "editor.formatOnSave": true,
          "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
          }
        },

        // TypeScript/JavaScript formatting
        "[typescript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[typescriptreact]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },
        "[javascript]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },

        // JSON formatting
        "[json]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },

        // Markdown formatting (Prettier, not Markdown All in One)
        "[markdown]": {
          "editor.wordWrap": "on",
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },

        // Disable Markdown All in One's formatter (conflicts with Prettier)
        "markdown.extension.formatting.enable": false,
        "markdown.extension.preview.autoShow": false,

        // YAML formatting
        "[yaml]": {
          "editor.defaultFormatter": "esbenp.prettier-vscode",
          "editor.formatOnSave": true
        },

        // File consistency
        "files.eol": "\n",
        "files.insertFinalNewline": true,
        "files.trimFinalNewlines": true,
        "files.trimTrailingWhitespace": true,

        // Python linting
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": false,
        "python.linting.mypyEnabled": false,
        "python.analysis.typeCheckingMode": "strict",
        "python.analysis.extraPaths": ["packages/src", "packages"],

        // Python testing (pytest)
        "python.testing.pytestEnabled": true,
        "python.testing.unittestEnabled": false,
        "python.testing.pytestArgs": ["tests", "-v", "--tb=short"],
        "python.testing.cwd": "${workspaceFolder}/packages",

        // Coverage Gutters - gutter icons + subtle ruler indicators
        "coverage-gutters.coverageFileNames": [
          "coverage.xml",
          "lcov.info",
          "coverage/lcov.info"
        ],
        "coverage-gutters.showGutterCoverage": true,
        "coverage-gutters.showLineCoverage": false,
        "coverage-gutters.showRulerCoverage": true,
        // Theme-matched colors: green (comments) = covered, orange (strings) = uncovered
        // Gutter uses full opacity, ruler uses subtle 0.3 opacity
        "coverage-gutters.highlightdark": "rgba(106, 153, 85, 0.3)",
        "coverage-gutters.highlightlight": "rgba(106, 153, 85, 0.3)",
        "coverage-gutters.noHighlightDark": "rgba(206, 145, 120, 0.3)",
        "coverage-gutters.noHighlightLight": "rgba(206, 145, 120, 0.3)",

        // Search and exclude patterns
        "search.exclude": {
          "**/__pycache__": true,
          "**/node_modules": true,
          "**/dist": true,
          "**/.venv": true,
          "**/.ty_cache": true,
          "**/build": true
        },

        // Hide intermediate coverage files
        "files.exclude": {
          "**/.coverage": true,
          "**/coverage.xml": true
        },

        // Show gitignored files like htmlcov/ in explorer
        "explorer.excludeGitIgnore": false,

        // GitHub integrations
        "github.gitAuthentication": true,
        "githubPullRequests.remotes": ["cosalette-apps", "origin", "upstream"],

        // Jinja template file associations — gives Jinja + host-language
        // dual syntax highlighting (requires samuelcolvin.jinjahtml extension)
        "files.associations": {
          "Dockerfile.jinja": "jinja-dockerfile",
          "*.sh.jinja": "jinja-shell",
          "*.toml.jinja": "jinja-toml",
          "*.json.jinja": "jinja-json",
          "*.yml.jinja": "jinja-yaml",
          "*.md.jinja": "jinja-md"
        },

        // Beads (bd) issue tracker — auto-start daemon on container open
        "beads.autoStartDaemon": true,

        // Window title
        "window.title": "cosalette-apps [devcontainer]"

        // Optional: theme colour customisations (uncomment to use)
        // "workbench.colorCustomizations": {
        //   "activityBar.background": "#1e1e2e",
        //   "statusBar.background": "#1e1e2e",
        //   "titleBar.activeBackground": "#1e1e2e"
        // }
      },
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "samuelcolvin.jinjahtml",

        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "anthropic.claude-code",
        "sst-dev.opencode",
        "vivaxy.vscode-conventional-commits",
        "ryanluker.vscode-coverage-gutters",
        "task.vscode-task",
        "planet57.vscode-beads",
        "fail-safe.copilot-premium-usage-monitor",
        "github.vscode-pull-request-github"
      ]
    }
  },

  "postCreateCommand": "/workspaces/cosalette-apps/.devcontainer/post-create.sh",
  "postStartCommand": "/workspaces/cosalette-apps/.devcontainer/post-start.sh",

  "remoteUser": "vscode"
}
