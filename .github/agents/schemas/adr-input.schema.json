{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ADR Input",
  "description": "Schema for structured ADR creation. Agents produce JSON conforming to this schema; scripts/render_adr.py transforms it into canonical Markdown.",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["new", "amendment", "supersede"],
      "description": "The kind of ADR operation. 'new' creates a fresh ADR. 'amendment' patches an existing ADR. 'supersede' creates a new ADR and marks the old one as superseded."
    }
  },
  "oneOf": [
    { "$ref": "#/definitions/new_adr" },
    { "$ref": "#/definitions/amendment_adr" },
    { "$ref": "#/definitions/supersede_adr" }
  ],
  "definitions": {
    "option": {
      "type": "object",
      "required": ["name", "description", "advantages", "disadvantages"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Short name for the option (e.g. 'pydantic-settings with BaseSettings')."
        },
        "description": {
          "type": "string",
          "description": "One-paragraph description of the option."
        },
        "advantages": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Advantages of this option."
        },
        "disadvantages": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Disadvantages of this option."
        },
        "chosen": {
          "type": "boolean",
          "default": false,
          "description": "Whether this is the chosen option. Exactly one option must have chosen=true."
        }
      }
    },
    "matrix_row": {
      "type": "object",
      "required": ["criterion", "scores"],
      "additionalProperties": false,
      "properties": {
        "criterion": {
          "type": "string",
          "description": "The evaluation criterion (e.g. 'Type safety', 'Maintenance burden')."
        },
        "scores": {
          "type": "object",
          "description": "Map of option name → score (1-5). Keys must match option names exactly.",
          "additionalProperties": {
            "type": "integer",
            "minimum": 1,
            "maximum": 5
          }
        }
      }
    },
    "sub_decision": {
      "type": "object",
      "required": ["title", "description"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string",
          "description": "Sub-decision heading (e.g. 'Port Naming Convention')."
        },
        "description": {
          "type": "string",
          "description": "Prose description of the sub-decision. May include Markdown formatting and code blocks."
        }
      }
    },
    "frontmatter": {
      "type": "object",
      "required": ["tags"],
      "additionalProperties": false,
      "properties": {
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
          },
          "minItems": 1,
          "maxItems": 6,
          "description": "Domain tags for categorisation. Must be lowercase kebab-case. Common tags: architecture, mqtt, configuration, logging, cli, testing, packaging, dependencies, lifecycle, telemetry, persistence, signal-filters, error-handling, health, scheduling, documentation, security, di, release."
        }
      }
    },
    "base_adr_fields": {
      "type": "object",
      "required": [
        "title",
        "date",
        "status",
        "impact",
        "context",
        "decision",
        "decision_drivers",
        "considered_options",
        "consequences_positive",
        "consequences_negative",
        "frontmatter"
      ],
      "properties": {
        "title": {
          "type": "string",
          "description": "ADR title without the number prefix (e.g. 'Configuration System', not 'ADR-003: Configuration System')."
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Decision date in YYYY-MM-DD format."
        },
        "status": {
          "type": "string",
          "enum": ["Proposed", "Accepted"],
          "description": "ADR status for new inputs. Use 'Proposed' for decisions under review, 'Accepted' for finalised decisions. Note: 'Superseded by ADR-NNN' is set programmatically by the renderer and is not a valid input value."
        },
        "impact": {
          "type": "string",
          "enum": ["low", "moderate", "high"],
          "description": "Impact level. Drives decision matrix requirements. high = new architectural pattern, cross-cutting concern, or breaking change. moderate = affects multiple modules or adds a new dependency. low = single-module convention, naming, or tooling choice."
        },
        "context": {
          "type": "string",
          "description": "The issue and context for the decision. Prose paragraphs with Markdown formatting. Include quantitative data where possible."
        },
        "decision": {
          "type": "string",
          "description": "The decision statement. Should start with 'Use <solution> for <problem> because <rationale>' or similar declarative form."
        },
        "decision_code_example": {
          "type": "string",
          "description": "Optional code example illustrating the decision. Will be rendered as a fenced code block."
        },
        "decision_code_language": {
          "type": "string",
          "default": "python",
          "description": "Language identifier for the code fence (e.g. 'python', 'yaml', 'bash')."
        },
        "decision_drivers": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 3,
          "description": "Key factors that influenced the decision."
        },
        "considered_options": {
          "type": "array",
          "items": { "$ref": "#/definitions/option" },
          "minItems": 2,
          "description": "Options that were evaluated. Exactly one must have chosen=true."
        },
        "decision_matrix": {
          "type": "array",
          "items": { "$ref": "#/definitions/matrix_row" },
          "description": "Decision matrix rows. Required for moderate/high impact. Each row scores all options on one criterion (1=poor, 5=excellent)."
        },
        "consequences_positive": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Positive consequences of the decision."
        },
        "consequences_negative": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Negative consequences of the decision."
        },
        "frontmatter": {
          "$ref": "#/definitions/frontmatter",
          "description": "Metadata for the rendered Markdown frontmatter block."
        }
      }
    },
    "new_adr": {
      "propertyNames": {
        "enum": [
          "type", "title", "date", "status", "impact", "context",
          "decision", "decision_code_example", "decision_code_language",
          "decision_drivers", "considered_options", "decision_matrix",
          "consequences_positive", "consequences_negative", "frontmatter"
        ]
      },
      "allOf": [
        { "$ref": "#/definitions/base_adr_fields" },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "new" }
          }
        },
        {
          "if": {
            "properties": { "impact": { "const": "high" } }
          },
          "then": {
            "properties": {
              "decision_matrix": { "minItems": 5 },
              "considered_options": { "minItems": 3 }
            },
            "required": ["decision_matrix"]
          }
        },
        {
          "if": {
            "properties": { "impact": { "const": "moderate" } }
          },
          "then": {
            "properties": {
              "decision_matrix": { "minItems": 3 }
            },
            "required": ["decision_matrix"]
          }
        }
      ]
    },
    "supersede_adr": {
      "propertyNames": {
        "enum": [
          "type", "title", "date", "status", "impact", "context",
          "decision", "decision_code_example", "decision_code_language",
          "decision_drivers", "considered_options", "decision_matrix",
          "consequences_positive", "consequences_negative", "frontmatter",
          "supersedes_adr"
        ]
      },
      "allOf": [
        { "$ref": "#/definitions/base_adr_fields" },
        {
          "type": "object",
          "required": ["type", "supersedes_adr"],
          "properties": {
            "type": { "const": "supersede" },
            "supersedes_adr": {
              "type": "string",
              "pattern": "^ADR-\\d{3}$",
              "description": "The ADR being superseded (e.g. 'ADR-014')."
            }
          }
        },
        {
          "if": {
            "properties": { "impact": { "const": "high" } }
          },
          "then": {
            "properties": {
              "decision_matrix": { "minItems": 5 },
              "considered_options": { "minItems": 3 }
            },
            "required": ["decision_matrix"]
          }
        },
        {
          "if": {
            "properties": { "impact": { "const": "moderate" } }
          },
          "then": {
            "properties": {
              "decision_matrix": { "minItems": 3 }
            },
            "required": ["decision_matrix"]
          }
        }
      ]
    },
    "amendment_adr": {
      "type": "object",
      "required": ["type", "target_adr", "amendment_scope", "amendment_date", "amendment_content"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "amendment" },
        "target_adr": {
          "type": "string",
          "pattern": "^ADR-\\d{3}$",
          "description": "The ADR to amend (e.g. 'ADR-006')."
        },
        "amendment_scope": {
          "type": "string",
          "enum": ["minor", "additive", "corrective"],
          "description": "Scope of the amendment. 'minor' = typo, clarification, code example. 'additive' = new sub-decisions, additional options, extend matrix. 'corrective' = change decision (requires justification why supersession is not warranted)."
        },
        "amendment_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Date of the amendment in YYYY-MM-DD format."
        },
        "amendment_rationale": {
          "type": "string",
          "description": "Why this amendment is being made. Required for additive and corrective scopes."
        },
        "amendment_justification": {
          "type": "string",
          "description": "Why supersession is not warranted. Required for corrective scope only. Must explain impact analysis (e.g. 'decision not yet implemented', 'impact on existing code is negligible')."
        },
        "amendment_content": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "notes": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Editorial notes or clarifications to append."
            },
            "sub_decisions": {
              "type": "array",
              "items": { "$ref": "#/definitions/sub_decision" },
              "description": "Fine-granular sub-decisions to add (e.g. naming conventions for an architectural pattern)."
            },
            "additional_options": {
              "type": "array",
              "items": { "$ref": "#/definitions/option" },
              "description": "New considered options to add to the record."
            },
            "additional_matrix_rows": {
              "type": "array",
              "items": { "$ref": "#/definitions/matrix_row" },
              "description": "New rows to add to the decision matrix."
            },
            "revised_decision": {
              "type": "string",
              "description": "Replacement decision statement. Only allowed for corrective amendments."
            },
            "revised_decision_code_example": {
              "type": "string",
              "description": "Replacement code example. Only allowed for corrective amendments."
            },
            "revised_decision_code_language": {
              "type": "string",
              "default": "python",
              "description": "Language for the revised code example fence."
            },
            "additional_consequences_positive": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Additional positive consequences."
            },
            "additional_consequences_negative": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Additional negative consequences."
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": { "amendment_scope": { "enum": ["additive", "corrective"] } }
          },
          "then": {
            "required": ["amendment_rationale"]
          }
        },
        {
          "if": {
            "properties": { "amendment_scope": { "const": "corrective" } }
          },
          "then": {
            "required": ["amendment_justification"]
          }
        },
        {
          "if": {
            "properties": { "amendment_scope": { "const": "minor" } }
          },
          "then": {
            "properties": {
              "amendment_content": {
                "properties": {},
                "not": {
                  "anyOf": [
                    { "required": ["additional_options"] },
                    { "required": ["additional_matrix_rows"] },
                    { "required": ["revised_decision"] },
                    { "required": ["revised_decision_code_example"] },
                    { "required": ["revised_decision_code_language"] },
                    { "required": ["sub_decisions"] }
                  ]
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": { "amendment_scope": { "const": "additive" } }
          },
          "then": {
            "properties": {
              "amendment_content": {
                "not": {
                  "anyOf": [
                    { "required": ["revised_decision"] },
                    { "required": ["revised_decision_code_example"] },
                    { "required": ["revised_decision_code_language"] }
                  ]
                }
              }
            }
          }
        }
      ]
    }
  }
}
