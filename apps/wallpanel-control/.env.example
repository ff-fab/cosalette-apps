# wallpanel-control environment configuration
# Copy this file to .env and fill in your values.
# Priority: CLI > env vars > .env > defaults

# ---------------------------------------------------------------------------
# MQTT
# ---------------------------------------------------------------------------

# WALLPANEL_CONTROL_MQTT__HOST=localhost
# WALLPANEL_CONTROL_MQTT__PORT=1883
# WALLPANEL_CONTROL_MQTT__USERNAME=
# WALLPANEL_CONTROL_MQTT__PASSWORD=
# Note: in production deployments with a broker password, prefer a Docker
# secret over storing the password in .env. See compose.yml for the pattern.
# WALLPANEL_CONTROL_MQTT__TOPIC_PREFIX=wallpanel-control

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# WALLPANEL_CONTROL_LOGGING__LEVEL=INFO
# WALLPANEL_CONTROL_LOGGING__FORMAT=json

# ---------------------------------------------------------------------------
# SSH
# ---------------------------------------------------------------------------

# WALLPANEL_CONTROL_SSH_HOST=wallpanel.lan
# WALLPANEL_CONTROL_SSH_USER=jl4
# WALLPANEL_CONTROL_SSH_PORT=22
# WALLPANEL_CONTROL_SSH_TIMEOUT=5.0

# Path to the SSH private key. In Docker Compose this is overridden to
# /run/secrets/wallpanel_ssh_key by the environment block in compose.yml.
# WALLPANEL_CONTROL_SSH_KEY_PATH=~/.ssh/wallpanel

# ---------------------------------------------------------------------------
# Backlight
# ---------------------------------------------------------------------------

# WALLPANEL_CONTROL_BACKLIGHT_PATH=/sys/class/backlight/intel_backlight/brightness

# ---------------------------------------------------------------------------
# Wake-on-LAN  (required)
# ---------------------------------------------------------------------------

# MAC address of the wall panel NIC that supports WoL.
WALLPANEL_CONTROL_WOL_MAC=AA:BB:CC:DD:EE:FF

# WALLPANEL_CONTROL_WOL_BROADCAST=255.255.255.255

# ---------------------------------------------------------------------------
# Docker Compose only
# ---------------------------------------------------------------------------

# Host path to the SSH private key mounted into the container.
# The container always reads from /run/secrets/wallpanel_ssh_key.
# HOST_WALLPANEL_SSH_KEY_PATH=/home/your-user/.ssh/wallpanel
