# jeelink2mqtt Configuration Template for Docker Deployment
#
# Copy this file to .env and customize values for your environment.
#
# See docs/reference.md for the full list of settings.

# ============================================================================
# Serial Connection
# ============================================================================

JEELINK2MQTT_SERIAL_PORT=/dev/ttyUSB0

# ============================================================================
# MQTT Broker
# ============================================================================

JEELINK2MQTT_MQTT__HOST=mosquitto
JEELINK2MQTT_MQTT__PORT=1883
# JEELINK2MQTT_MQTT__USERNAME=mqtt_user
# JEELINK2MQTT_MQTT__PASSWORD=mqtt_pass

# ============================================================================
# Sensor Configuration
# ============================================================================

# JSON array of sensor definitions (name is required, other fields optional)
JEELINK2MQTT_SENSORS=[{"name": "office", "temp_offset": -0.5}, {"name": "outdoor", "staleness_timeout": 900}]

# Global staleness timeout (seconds) — sensors with no reading within this
# window are marked offline
JEELINK2MQTT_STALENESS_TIMEOUT_SECONDS=600

# Median filter window size for smoothing readings
JEELINK2MQTT_MEDIAN_FILTER_WINDOW=7
